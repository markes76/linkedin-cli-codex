{
  "name": "linkedin-cli",
  "version": "0.1.0",
  "description": "Unofficial CLI for LinkedIn. Structured JSON output. Agent skill included. Built for Claude Code, Cursor, Codex, and other agentic tools.",
  "type": "module",
  "author": "Mark Samuelson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/markes76/linkedin-cli.git"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "linkedin": "./dist/cli.js",
    "linkedin-cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs/skill.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run validate-skill && tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "validate-skill": "node scripts/validate-skill.mjs",
    "browsers:install": "playwright install chrome",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run build"
  },
  "keywords": [
    "linkedin",
    "cli",
    "typescript",
    "ai-agents",
    "mcp",
    "claude-code",
    "cursor",
    "codex",
    "automation",
    "playwright"
  ],
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "clipboardy": "^5.3.1",
    "commander": "^14.0.0",
    "csv-stringify": "^6.5.2",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
