{
  "name": "linkedin-cli",
  "version": "0.1.3",
  "description": "Unofficial LinkedIn CLI for agentic coding tools",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "linkedin": "./dist/cli.js",
    "linkedin-cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "docs/skill.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "browsers:install": "playwright install chrome",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run build"
  },
  "keywords": [
    "linkedin",
    "cli",
    "voyager",
    "playwright",
    "agent",
    "claude-code",
    "cursor",
    "codex"
  ],
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.0",
    "csv-stringify": "^6.5.2",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  }
}
